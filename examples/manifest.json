  "scenarios": [
    {
      "id": "in-memory-generator",
      "source_id": "in-memory",
      "title": "In-memory generator → Iceberg (fixture)",
      "description": "Retained as a test fixture for the sidecar-free/loopback code path (quota, /metrics, action error-truthfulness integration tests). Its actions issue ANSI Iceberg DDL/DML (CREATE TABLE / INSERT / ALTER / SELECT against warehouse.*) that /api/v1/sql does not execute — the parser is management-DDL only by design. Not promoted to any user-facing deployment.",
      "difficulty": "beginner",
      "tier": 1,
      "status": "beta",
      "tags": [
        "synthetic",
        "iceberg",
        "test-fixture"
      ],
      "prerequisites": {
        "deployment": [
          "dev",
          "self-managed"
        ],
        "profiles": [],
        "min_memory_mb": 256
      },
      "estimated_duration_s": 90,
      "actions": [
        {
          "id": "create-table",
          "label": "Create demo table",
          "kind": "sql",
          "target": "ops",
          "sql": "CREATE TABLE IF NOT EXISTS warehouse.{namespace}.demo_orders (id BIGINT, customer VARCHAR, total_cents BIGINT, status VARCHAR, created_at TIMESTAMP);"
        },
        {
          "id": "burst-100",
          "label": "Insert 100 synthetic rows",
          "kind": "sql",
          "target": "ops",
          "sql": "INSERT INTO warehouse.{namespace}.demo_orders SELECT seq AS id, CONCAT('customer-', seq) AS customer, CAST(seq * 137 AS BIGINT) AS total_cents, CASE WHEN seq % 4 = 0 THEN 'pending' WHEN seq % 4 = 1 THEN 'shipped' WHEN seq % 4 = 2 THEN 'delivered' ELSE 'returned' END AS status, CURRENT_TIMESTAMP AS created_at FROM UNNEST(SEQUENCE(1, 100)) AS t(seq);"
        },
        {
          "id": "schema-add-field",
          "label": "Add 'priority' column",
          "kind": "sql",
          "target": "ops",
          "sql": "ALTER TABLE warehouse.{namespace}.demo_orders ADD COLUMN priority VARCHAR;"
        },
        {
          "id": "query-recent",
          "label": "Count rows landed",
          "kind": "sql",
          "target": "ops",
          "sql": "SELECT COUNT(*) AS row_count FROM warehouse.{namespace}.demo_orders;"
        }
      ],
      "break_scenarios": [
        {
          "id": "schema-drop-field",
          "label": "Drop 'priority' column",
          "kind": "sql",
          "target": "ops",
          "sql": "ALTER TABLE warehouse.{namespace}.demo_orders DROP COLUMN priority;",
          "destructive": true
        }
      ],
      "expected_outcomes": [
        {
          "metric": "rows_landed",
          "assertion": "gte",
          "value": 100
        }
      ]
    },
    {
      "id": "postgres-cdc-ecommerce",
      "source_id": "postgres",
      "title": "PostgreSQL CDC — e-commerce happy path",
      "description": "Logical replication from a 9.6K-row e-commerce schema into Iceberg. Insert, update, and delete orders from the UI and watch them land.",
      "difficulty": "beginner",
      "tier": 1,
      "status": "stable",
      "tags": [
        "cdc",
        "happy-path",
        "postgres"
      ],
      "prerequisites": {
        "deployment": [
          "dev",
          "self-managed",
          "cloud"
        ],
        "profiles": [],
        "min_memory_mb": 1024
      },
      "init_sql": "postgres-cdc/init.sql",
      "shuttle_sql": "playground/postgres-cdc/shuttle.sql",
      "estimated_duration_s": 180,
      "actions": [
        {
          "id": "insert-order",
          "label": "Insert order",
          "kind": "sql",
          "target": "source",
          "sql_file": "postgres-cdc/actions/insert-order.sql"
        },
        {
          "id": "update-order",
          "label": "Update order status",
          "kind": "sql",
          "target": "source",
          "sql_file": "postgres-cdc/actions/update-order.sql"
        },
        {
          "id": "delete-order",
          "label": "Delete oldest order",
          "kind": "sql",
          "target": "source",
          "sql_file": "postgres-cdc/actions/delete-order.sql"
        },
        {
          "id": "burst-100",
          "label": "Burst: 100 inserts",
          "kind": "sql",
          "target": "source",
          "sql_file": "postgres-cdc/actions/burst-100.sql",
          "repeat": 1
        }
      ],
      "break_scenarios": [
        {
          "id": "drop-column",
          "label": "Drop tracked column",
          "kind": "sql",
          "target": "source",
          "sql": "ALTER TABLE orders DROP COLUMN status;",
          "destructive": true
        },
        {
          "id": "rename-table",
          "label": "Rename tracked table",
          "kind": "sql",
          "target": "source",
          "sql": "ALTER TABLE orders RENAME TO orders_v2;",
          "destructive": true
        }
      ],
      "expected_outcomes": [
        {
          "metric": "rows_landed",
          "assertion": "gte",
          "value": 9600
        },
        {
          "metric": "dlq_count",
          "assertion": "eq",
          "value": 0
        }
      ]
    },
    {
      "id": "postgres-schema-evolution",
      "source_id": "postgres",
      "title": "Schema evolution — ADD / DROP / RENAME",
      "description": "Watch Iceberg absorb column additions, drops, renames, and type widenings without shuttle interruption.",
      "difficulty": "intermediate",
      "tier": 1,
      "status": "stable",
      "tags": [
        "cdc",
        "schema-evolution",
        "postgres",
        "cloud"
      ],
      "prerequisites": {
        "deployment": [
          "dev",
          "self-managed",
          "cloud"
        ],
        "profiles": []
      },
      "init_sql": "postgres-cdc/init.sql",
      "shuttle_sql": "playground/postgres-cdc/shuttle.sql",
      "estimated_duration_s": 240,
      "actions": [
        {
          "id": "add-column",
          "label": "ADD COLUMN shipping_fee NUMERIC",
          "kind": "sql",
          "target": "source",
          "sql": "ALTER TABLE orders ADD COLUMN shipping_fee NUMERIC(10,2) DEFAULT 0;"
        },
        {
          "id": "widen-type",
          "label": "ALTER TYPE integer → bigint",
          "kind": "sql",
          "target": "source",
          "sql": "ALTER TABLE orders ALTER COLUMN total_cents TYPE BIGINT;"
        },
        {
          "id": "rename-column",
          "label": "RENAME COLUMN",
          "kind": "sql",
          "target": "source",
          "sql": "ALTER TABLE orders RENAME COLUMN notes TO customer_notes;"
        },
        {
          "id": "drop-column",
          "label": "DROP COLUMN (soft)",
          "kind": "sql",
          "target": "source",
          "sql": "ALTER TABLE orders DROP COLUMN internal_tag;",
          "destructive": true
        }
      ],
      "expected_outcomes": [
        {
          "metric": "schema_evolution_events",
          "assertion": "gte",
          "value": 4
        }
      ]
    },
    {
      "id": "postgres-backfill-plus-live",
