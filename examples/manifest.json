          "metric": "dedup_gap_offsets",
          "assertion": "eq",
          "value": 0
        }
      ]
    },
    {
      "id": "clickhouse-high-cardinality",
      "source_id": "clickhouse",
      "title": "ClickHouse — high-cardinality clustering",
      "description": "Load 100k web analytics events, tune Iceberg clustering key live and watch query plans change.",
      "difficulty": "intermediate",
      "tier": 1,
      "status": "stable",
      "tags": [
        "snapshot",
        "clickhouse",
        "clustering"
      ],
