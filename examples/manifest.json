      "shuttle_sql": "playground/clickhouse-snapshot/shuttle.sql",
      "estimated_duration_s": 300,
      "actions": [
        {
          "id": "load-100k",
          "label": "Load 100k events",
          "kind": "sql",
          "target": "source",
          "sql_file": "playground/clickhouse-snapshot/actions/load-100k.sql"
        },
        {
          "id": "cluster-by-user",
          "label": "Cluster by user_id",
          "kind": "http",
          "target": "ops",
          "http_request": {
            "method": "PUT",
            "url": "/api/v1/shuttles/{shuttle}/clustering",
            "body": {
              "tables": {
                "": {
                  "sort_order": {
                    "fields": [
                      {
                        "column": "user_id",
                        "transform": "Identity",
                        "direction": "Asc",
                        "null_order": null
                      }
                    ]
                  }
                }
              },
              "apply_to_existing_tables": false
            }
          }
        },
        {
          "id": "cluster-by-session",
          "label": "Cluster by session+time",
          "kind": "http",
          "target": "ops",
          "http_request": {
            "method": "PUT",
            "url": "/api/v1/shuttles/{shuttle}/clustering",
            "body": {
              "tables": {
                "": {
                  "sort_order": {
                    "fields": [
                      {
                        "column": "session_id",
                        "transform": "Identity",
                        "direction": "Asc",
                        "null_order": null
                      },
                      {
                        "column": "event_time",
                        "transform": "Identity",
                        "direction": "Asc",
                        "null_order": null
                      }
                    ]
                  }
                }
              },
              "apply_to_existing_tables": false
            }
          }
        }
      ],
      "expected_outcomes": [
        {
          "metric": "query_time_improvement_pct",
          "assertion": "gte",
          "value": 30
        }
      ]
    },
    {
      "id": "clickhouse-time-travel",
      "source_id": "clickhouse",
      "title": "Iceberg time travel — query at timestamp / rollback",
